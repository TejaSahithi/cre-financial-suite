# Supabase Configuration
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Vertex AI — required for PDF lease extraction
# Set these via Supabase secrets (NOT in .env — they are server-side only):
#   supabase secrets set VERTEX_PROJECT_ID=your-gcp-project-id
#   supabase secrets set VERTEX_LOCATION=us-central1
#   supabase secrets set GOOGLE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"...",...}'
#
# The service account needs the "Vertex AI User" IAM role on your GCP project.

# Optional: Docling service for better PDF text extraction (before Vertex AI)
# DOCLING_API_URL=http://your-docling-service:5001
# DOCLING_API_KEY=your-docling-key

# Optional: Resend API key for invite emails (server-side only — do NOT use VITE_ prefix)
# RESEND_API_KEY=re_xxxxxx

# Optional: Login redirect URL
# VITE_LOGIN_URL=/Login
